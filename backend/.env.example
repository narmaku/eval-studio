# eval-studio backend environment configuration
# Copy this file to .env and update values as needed.

# Database connection string (default: local SQLite with async driver)
# DATABASE_URL=sqlite+aiosqlite:///./eval_studio.db

# API key for LiteLLM judge models (required for LLM-as-judge evaluations)
# LITELLM_API_KEY=sk-...

# Default judge model used by the LiteLLM adapter
# LITELLM_MODEL=gpt-4.1

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# LOG_LEVEL=INFO

# Comma-separated list of allowed CORS origins
# CORS_ORIGINS=["http://localhost:5173"]

# Enable debug mode (verbose logging, auto-reload, etc.)
# DEBUG=false

# Enable authentication (OIDC). When false, all requests are unauthenticated.
# AUTH_ENABLED=false
