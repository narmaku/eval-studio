# Inference provider profiles for eval-studio
# Each provider is a named endpoint that can be selected in the UI.
# Copy this file to providers.yaml and customize for your environment.
#
# Required fields: id, name, default_model
# Optional: api_key_env, api_base, tags, proxy, ssl_cert_path, default_params
#
# Any provider can be used as a judge — no separate "judge" entry needed.

providers:
  - id: openai-gpt4
    name: "OpenAI GPT-4.1"
    default_model: "gpt-4.1"
    api_key_env: "OPENAI_API_KEY"
    tags: ["openai"]

  - id: ollama-local
    name: "Local Ollama"
    default_model: "ollama/llama3.2:3b"
    api_base: "http://localhost:11434"
    tags: ["local", "dev", "free"]

  # Custom (non-LiteLLM) provider example:
  # - id: my-custom-api
  #   name: "Custom API"
  #   default_model: "my-model"
  #   provider_type: "custom"
  #   endpoint_url: "https://my-host/api/v1/infer"
  #   request_body_template: '{"prompt": "{{message}}", "model": "{{model}}"}'
  #   response_json_path: "output.text"
  #   single_model: true
