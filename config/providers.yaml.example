# Inference provider profiles for eval-studio
# Each provider is a named endpoint that can be selected in the UI.
# Copy this file to providers.yaml and customize for your environment.

providers:
  - id: openai-gpt4
    name: "OpenAI GPT-4.1"
    litellm_model: "gpt-4.1"
    api_key_env: "OPENAI_API_KEY"
    tags: ["openai"]
    purpose: "test"

  - id: ollama-local
    name: "Local Ollama"
    litellm_model: "ollama/llama3.2:3b"
    api_base: "http://localhost:11434"
    tags: ["local", "dev", "free"]
    purpose: "test"

  - id: judge-gpt4
    name: "Judge - GPT-4.1"
    litellm_model: "gpt-4.1"
    api_key_env: "OPENAI_API_KEY"
    tags: ["judge"]
    purpose: "judge"
