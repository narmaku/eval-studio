# Tool server (MCP) definitions for eval-studio
# Each entry defines an MCP server or standalone tool collection.
# Copy this file to tool_servers.yaml and customize for your environment.

tool_servers:
  - id: example-filesystem
    name: Filesystem MCP Server (Example)
    type: mcp_stdio
    command: npx
    args:
      - '-y'
      - '@modelcontextprotocol/server-filesystem'
      - /tmp/sandbox
    description: Read-only filesystem access for the agent (disabled by default)
    tags:
      - filesystem
      - example
    enabled: false
