# =============================================================================
# eval-studio environment configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# All backend settings are loaded via Pydantic Settings (backend/app/core/config.py).
# Frontend variables must be prefixed with VITE_ (Vite convention).
# Registry config paths have sensible auto-discovery defaults and rarely need
# to be set manually.

# -----------------------------------------------------------------------------
# Core / Application
# -----------------------------------------------------------------------------

# Enable debug mode (verbose logging, auto-reload in dev, etc.)
DEBUG=false

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# SQLite connection string (default for single-node / MVP setup).
# The database file is created automatically on first run.
DATABASE_URL=sqlite+aiosqlite:///./eval_studio.db

# -----------------------------------------------------------------------------
# LLM Provider (via LiteLLM)
# -----------------------------------------------------------------------------
# eval-studio uses LiteLLM as a universal LLM gateway. These variables are
# the global defaults; per-evaluation overrides are configured via Provider
# Profiles (config/providers.yaml or the UI).

# API key for the default LLM provider (OpenAI, Anthropic, etc.)
# LITELLM_API_KEY=sk-placeholder-replace-me

# Default model identifier used as fallback when no provider is selected.
# (e.g. gpt-4.1, claude-sonnet-4-20250514, mistral-large)
# DEFAULT_MODEL=gpt-4.1

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------

# Disable API key authentication. Defaults to true (auth off) for local dev.
# Set to false in production to require Bearer token auth on all endpoints.
AUTH_DISABLED=true

# Path to a custom CA certificate bundle. Required in corporate environments
# with TLS-intercepting proxies. Sets SSL_CERT_FILE, REQUESTS_CA_BUNDLE, and
# CURL_CA_BUNDLE for outgoing LLM calls.
# SSL_CERT_FILE=/etc/pki/tls/certs/ca-bundle.crt

# Comma-separated list of allowed CORS origins.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Comma-separated list of allowed harness binary paths (e.g., /usr/bin/goose,/usr/local/bin/python3)
# Leave empty to block all harness subprocess execution (secure default)
HARNESS_ALLOWED_BINARIES=

# Comma-separated list of allowed tool server commands (e.g., /usr/bin/npx,/usr/bin/node,/usr/bin/python3)
# Leave empty to block all tool server subprocess execution (secure default)
TOOL_SERVER_ALLOWED_COMMANDS=

# -----------------------------------------------------------------------------
# Config Paths (YAML Registry Overrides)
# -----------------------------------------------------------------------------
# Each registry auto-discovers its config file relative to the repo root
# (config/<name>.yaml). Set these only if you need a custom location.

# Path to evaluators.yaml (evaluator adapter definitions)
# EVALUATORS_CONFIG_PATH=config/evaluators.yaml

# Path to providers.yaml (inference provider profiles)
# PROVIDERS_CONFIG_PATH=config/providers.yaml

# Path to harnesses.yaml (agent harness profiles)
# HARNESS_CONFIG_PATH=config/harnesses.yaml

# Path to tool_servers.yaml (MCP / standalone tool definitions)
# TOOL_SERVERS_CONFIG_PATH=config/tool_servers.yaml

# Directory for evaluator configuration (legacy; used by the evaluators API)
EVALUATOR_CONFIG_DIR=config/evaluators

# -----------------------------------------------------------------------------
# Artifacts & Timeouts
# -----------------------------------------------------------------------------

# Directory for evaluation artifact storage (relative to backend working dir)
# ARTIFACTS_DIR=data/artifacts

# Default timeout (seconds) for the synchronous run-and-wait endpoint
# RUN_TIMEOUT_DEFAULT=300

# Maximum allowed timeout for the run-and-wait endpoint
# RUN_TIMEOUT_MAX=600

# -----------------------------------------------------------------------------
# Dataset Import Settings
# -----------------------------------------------------------------------------

# Maximum size of a single uploaded file in bytes (default: 10 MB)
MAX_IMPORT_FILE_SIZE=10485760

# Maximum aggregate size across all files in one import (default: 100 MB)
MAX_IMPORT_TOTAL_SIZE=104857600

# Maximum number of files per import
MAX_IMPORT_FILES=50

# Number of sample rows returned in the import preview
IMPORT_SAMPLE_ROWS=20

# -----------------------------------------------------------------------------
# Frontend (Vite)
# -----------------------------------------------------------------------------
# In development the Vite dev server proxies /api requests to the backend, so
# this variable is usually left unset. Set it only when the frontend is served
# from a different origin than the API (e.g. a CDN or a separate container).
# VITE_API_BASE_URL=http://localhost:8000
