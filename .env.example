# eval-studio environment configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Database ---
# SQLite connection string (default for MVP)
DATABASE_URL=sqlite+aiosqlite:///./eval_studio.db

# --- LLM Provider (via LiteLLM) ---
# API key for judge models (OpenAI, Anthropic, etc.)
LITELLM_API_KEY=sk-placeholder-replace-me
# Default judge model identifier
LITELLM_MODEL=gpt-4.1
# LiteLLM proxy base URL (if using external proxy)
# LITELLM_API_BASE=http://localhost:4000

# --- Application ---
# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# Host and port for backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# --- Environment Provisioning ---
# Testing Farm API token (for TMT environments)
# TESTING_FARM_API_TOKEN=
# Testing Farm API URL
# TESTING_FARM_API_URL=https://api.dev.testing-farm.io

# --- Optional: External Services ---
# MLflow tracking URI (for result export, post-MVP)
# MLFLOW_TRACKING_URI=http://localhost:5000
